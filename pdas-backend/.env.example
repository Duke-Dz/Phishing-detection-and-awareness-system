# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=debug
CONSOLE_LOG_LEVEL=http
LOG_DIR=logs
LOG_MAX_SIZE_BYTES=10485760
LOG_MAX_FILES=10

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cybersense_db
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Admin seed account (required only when running seeders)
SEED_ADMIN_NAME="System Administrator"
SEED_ADMIN_USERNAME=system_admin
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=15m
NORMAL_SESSION_IDLE_MINUTES=30
NORMAL_SESSION_ABSOLUTE_HOURS=8
REMEMBER_ME_IDLE_DAYS=7
REFRESH_TOKEN_EXPIRES_DAYS=30
AUTH_COOKIE_NAME=refresh_token
AUTH_COOKIE_SAME_SITE=lax

# HTTPS (disable for local development)
HTTPS_ENABLED=false
FORCE_HTTPS=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Scan Worker (run with npm run start:worker)
SCAN_WORKER_INTERVAL_MS=5000
SCAN_WORKER_BATCH_SIZE=5
SCAN_JOB_MAX_ATTEMPTS=3

# Email (configure when needed)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="PDAS Security <noreply@pdas.local>"
SUPPORT_EMAIL=support@pdas.local

# External Threat Intelligence
# Optional: the system works without keys, but these improve Layer 2 detection.
# Demo default: local/cache first, Google Safe Browsing for URL checks,
# VirusTotal only for suspicious/high-risk URLs or Google hits.
EXTERNAL_THREAT_MODE=gated
GOOGLE_SAFE_BROWSING_ENABLED=true
VIRUSTOTAL_ENABLED=true
VIRUSTOTAL_MIN_LOCAL_SCORE=50
EXTERNAL_THREAT_CACHE_TTL_MINUTES=60
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# Token Expiry
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60
PASSWORD_RESET_RESPONSE_DELAY_MS=300
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24
