# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phishguard_db
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SYNC_ALTER=true

# ── Authentication ───────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30
MFA_ISSUER=PDAS

# ── HTTPS (disable for local development) ────────────────
HTTPS_ENABLED=false
FORCE_HTTPS=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# ── Scan Worker ──────────────────────────────────────────
SCAN_WORKER_ENABLED=true
WORKER_ONLY=false
SCAN_WORKER_INTERVAL_MS=5000
SCAN_WORKER_BATCH_SIZE=5
SCAN_JOB_MAX_ATTEMPTS=3

# ── Email (configure when needed) ────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="PDAS Security <noreply@pdas.local>"

# ── External Threat Intelligence API Keys ────────────────
# Optional — system works without these but enables Layer 2 detection
# SECURITY: Never commit real values to version control
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Token Expiry ─────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24
