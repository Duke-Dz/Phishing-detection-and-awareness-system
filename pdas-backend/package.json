{
  "name": "cybersense-backend",
  "version": "1.0.0",
  "description": "Backend API for CyberSense — an evidence-weighted phishing detection and awareness platform",
  "main": "server.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/security-utils.test.js tests/unit/**/*.test.js",
    "test:integration": "node --test tests/integration/**/*.test.js",
    "test:detector": "node --test tests/unit/emailParser.test.js tests/unit/externalThreatService.test.js tests/unit/threatIntelService.test.js tests/integration/emailDetection.test.js tests/integration/emailEvidenceCalibration.test.js",
    "test:database": "node --test tests/database/**/*.test.js",
    "check": "node scripts/check-syntax.js",
    "start": "node server.js",
    "start:worker": "node worker.js",
    "dev": "nodemon server.js",
    "dev:worker": "nodemon worker.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:repair-security-events": "node scripts/repair-security-events.js",
    "mail:test": "node scripts/test-mail.js",
    "db:seed": "sequelize-cli db:seed:all",
    "db:undo": "sequelize-cli db:migrate:undo"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "he": "^1.2.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.35",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true
  }
}
