        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "http://{{base_url}}/api/metrics", "host": ["{{base_url}}"], "path": ["api", "metrics"], "protocol": "http" }
          }
        }
      ]
    }
  ]
}
