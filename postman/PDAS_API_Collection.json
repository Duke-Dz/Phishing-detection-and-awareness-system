        {
          "name": "API Key Status (Validate Keys)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "http://{{base_url}}/api/admin/api-status", "host": ["{{base_url}}"], "path": ["api", "admin", "api-status"], "protocol": "http" }
          }
